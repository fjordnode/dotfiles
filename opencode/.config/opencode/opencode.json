{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/instructions.md"
  ],
  "model": "openai/gpt-5.5",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git checkout": "ask",
      "git checkout *": "ask",
      "git switch": "ask",
      "git switch *": "ask",
      "git restore": "ask",
      "git restore *": "ask",
      "git reset": "ask",
      "git reset *": "ask",
      "git clean": "ask",
      "git clean *": "ask",
      "git rebase": "ask",
      "git rebase *": "ask",
      "git merge": "ask",
      "git merge *": "ask",
      "rm": "ask",
      "rm *": "ask",
      "/bin/rm": "ask",
      "/bin/rmdir": "ask",
      "mv *": "ask",
      "mkdir *": "ask",
      "ls": "allow",
      "ls *": "allow",
      "/bin/ls": "allow",
      "/bin/ls *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "find": "allow",
      "find *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "uniq": "allow",
      "uniq *": "allow",
      "stat": "allow",
      "stat *": "allow",
      "pwd": "allow",
      "which": "allow",
      "tree": "allow",
      "tree *": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.pem": "ask",
      "*.key": "ask",
      "*.p12": "ask",
      "*.pfx": "ask",
      "*.crt": "ask",
      "*.cer": "ask",
      "*.der": "ask",
      "*/.ssh/*": "ask",
      "*/.aws/*": "ask",
      "*/.gnupg/*": "ask",
      "*/.docker/config.json": "ask",
      "*/.kube/config": "ask",
      "*/.npmrc": "ask",
      "*/.pypirc": "ask",
      "*/.git-credentials": "ask",
      "*/.netrc": "ask"
    },
    "external_directory": {
      "*": "ask",
      "/opt/docker/compose": "allow",
      "/opt/docker/compose/*": "allow"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "task": "ask"
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.3-codex"
    },
    "code-explorer": {
      "model": "openai/gpt-5.3-codex"
    },
    "general": {
      "disable": true
    }
  }
}
