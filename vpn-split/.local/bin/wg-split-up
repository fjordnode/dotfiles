#!/bin/bash
set -euo pipefail

. /home/hugo/.local/lib/wg-split-lib.sh

MARK=0x6e76
TABLE=26642
FULL_TUNNELS=(wg-proton wg-home)
PREFERRED_IFACE="${1:-}"

count_full_tunnels_up() {
    local count=0
    local iface
    for iface in "${FULL_TUNNELS[@]}"; do
        if iface_is_up "$iface"; then
            count=$((count + 1))
        fi
    done
    printf '%s\n' "$count"
}

wait_for_iface_down() {
    local iface="${1:-}"
    local tries=10

    while [ "$tries" -gt 0 ]; do
        if ! iface_is_up "$iface"; then
            return 0
        fi
        sleep 0.2
        tries=$((tries - 1))
    done

    return 1
}

# Any full-tunnel interface up? The bypass target is the physical gateway,
# so we don't care which tunnel is carrying normal traffic — only that one
# of the supported full-tunnel modes is active.
WG_UP=""
for iface in "${FULL_TUNNELS[@]}"; do
    if iface_is_up "$iface"; then
        WG_UP="$iface"
        break
    fi
done

if [ -z "$WG_UP" ]; then
    echo "wg-split-up: no full-tunnel WG interface up, skipping" >&2
    exit 0
fi

if [ "$(count_full_tunnels_up)" -gt 1 ]; then
    if [ -z "$PREFERRED_IFACE" ] || [[ ! " ${FULL_TUNNELS[*]} " =~ " ${PREFERRED_IFACE} " ]] || ! iface_is_up "$PREFERRED_IFACE"; then
        PREFERRED_IFACE="$(read_preferred_tunnel 2>/dev/null || true)"
    fi

    if [ -z "$PREFERRED_IFACE" ] || [[ ! " ${FULL_TUNNELS[*]} " =~ " ${PREFERRED_IFACE} " ]] || ! iface_is_up "$PREFERRED_IFACE"; then
        echo "wg-split-up: multiple full-tunnel interfaces are up, but no valid preferred interface was supplied" >&2
        exit 1
    fi

    WG_UP="$PREFERRED_IFACE"

    for iface in "${FULL_TUNNELS[@]}"; do
        [ "$iface" = "$WG_UP" ] && continue
        iface_is_up "$iface" || continue
        echo "wg-split-up: multiple full-tunnel interfaces detected; keeping $WG_UP and bringing down $iface" >&2
        if ! nmcli connection down "$iface" >/dev/null 2>&1; then
            echo "wg-split-up: failed to bring down $iface via nmcli" >&2
            exit 1
        fi
        if ! wait_for_iface_down "$iface"; then
            echo "wg-split-up: $iface is still up after requested shutdown" >&2
            exit 1
        fi
    done
fi

ROUTE=$(ip route show table main default 2>/dev/null | head -1)
if [ -z "$ROUTE" ]; then
    echo "wg-split-up: no default route in main table" >&2
    exit 1
fi

GATEWAY=$(echo "$ROUTE" | grep -oP 'via \K\S+')
DEVICE=$(echo "$ROUTE" | grep -oP 'dev \K\S+')

if [ -z "$GATEWAY" ] || [ -z "$DEVICE" ]; then
    echo "wg-split-up: cannot parse route: $ROUTE" >&2
    exit 1
fi

CGROUP_PATH="$(cgroup_path || true)"
if [ -z "$CGROUP_PATH" ] || [ ! -d "/sys/fs/cgroup/$CGROUP_PATH" ]; then
    echo "wg-split-up: novpn.slice cgroup not found (is novpn-anchor.service running?)" >&2
    exit 1
fi

# Bypass table: copy local subnet routes + real default gateway
while IFS= read -r route; do
    ip route replace $route table $TABLE 2>/dev/null || true
done < <(ip route show table main scope link)
ip route replace default via "$GATEWAY" dev "$DEVICE" table $TABLE

# Policy rule: marked packets use bypass table
ip rule del fwmark $MARK table $TABLE 2>/dev/null || true
ip rule add fwmark $MARK table $TABLE priority 100

# nftables: mark packets from novpn.slice cgroup + connmark for replies
nft delete table inet split-tunnel 2>/dev/null || true
nft -f - <<EOF
table inet split-tunnel {
    chain mark-bypass {
        type route hook output priority mangle; policy accept;
        ct mark $MARK meta mark set ct mark counter comment "restore from connmark"
        meta mark != $MARK socket cgroupv2 level 4 "$CGROUP_PATH" meta mark set $MARK counter comment "cgroup match"
        meta mark $MARK ct mark set meta mark counter comment "save to connmark"
    }
    chain restore-inbound {
        type filter hook prerouting priority mangle; policy accept;
        ct mark $MARK meta mark set ct mark counter comment "restore inbound"
    }
    chain snat-bypass {
        type nat hook postrouting priority srcnat; policy accept;
        meta mark $MARK oifname "$DEVICE" counter masquerade
    }
}
EOF

# Build list of configured full-tunnel peer endpoints (IP + port) so the
# kill-switch can stay fail-closed even while switching modes. Prefer the
# live endpoint from `wg show` when the interface is up; fall back to the
# NetworkManager profile when it is down.
WG_ENDPOINT_RULES=""
declare -A seen_endpoints=()
for iface in "${FULL_TUNNELS[@]}"; do
    endpoint="$(configured_endpoint "$iface")"
    [ -n "$endpoint" ] || continue
    [ -n "${seen_endpoints[$endpoint]:-}" ] && continue
    seen_endpoints["$endpoint"]=1
    WG_ENDPOINT_RULES+="$(endpoint_rule "$iface" "$endpoint" "wg-split-up")"$'\n'
done

# Kill-switch lives in a SEPARATE table so it persists across wg up/down cycles.
# wg-split-down keeps this table alive. Use wg-kill-switch-off to disable explicitly.
nft delete table inet kill-switch 2>/dev/null || true
nft -f - <<EOF
table inet kill-switch {
    chain kill {
        type filter hook output priority 0; policy accept;
        # Allow non-physical interfaces (loopback, wg*, etc.)
        oifname != "$DEVICE" counter accept comment "non-physical"
        # Allow LAN IPv4
        ip daddr 10.10.0.0/24 counter accept comment "LAN v4"
        # Allow IPv6 link-local
        ip6 daddr fe80::/10 counter accept comment "v6 link-local"
        # Allow WG peer endpoints for the full-tunnel modes so switching can
        # succeed even while the kill-switch is active.
$WG_ENDPOINT_RULES
        # Allow novpn bypass
        meta mark $MARK counter accept comment "novpn mark"
        # Anything still here headed to physical interface gets dropped
        counter drop comment "kill"
    }
}
EOF

STATE_FILE="$(state_file)"
mkdir -p "$(dirname "$STATE_FILE")"
: > "$STATE_FILE"
if [ "$(id -u)" -eq 0 ] && [ -n "${SUDO_USER:-}" ]; then
    chown "$SUDO_USER":"$SUDO_USER" "$STATE_FILE" 2>/dev/null || true
fi

PREFERRED_FILE="$(preferred_tunnel_file)"
mkdir -p "$(dirname "$PREFERRED_FILE")"
printf '%s\n' "$WG_UP" > "$PREFERRED_FILE"

echo "wg-split-up: bypass via $GATEWAY dev $DEVICE (active tunnel: $WG_UP)"
