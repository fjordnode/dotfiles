{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/instructions.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git checkout": "ask",
      "git checkout *": "ask",
      "git switch": "ask",
      "git switch *": "ask",
      "git restore": "ask",
      "git restore *": "ask",
      "git reset": "ask",
      "git reset *": "ask",
      "git clean": "ask",
      "git clean *": "ask",
      "git rebase": "ask",
      "git rebase *": "ask",
      "git merge": "ask",
      "git merge *": "ask",
      "rm": "ask",
      "rm *": "ask",
      "/bin/rm": "ask",
      "/bin/rmdir": "ask",
      "mv *": "allow",
      "mkdir *": "allow"
    }
  },
  "plugin": [
    "oh-my-opencode-slim",
    "opencode-anthropic-auth@latest"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
  }
}
