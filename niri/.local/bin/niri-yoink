#!/bin/bash
# Capture focused window BEFORE kitty steals focus
eval "$(niri msg -j focused-window 2>/dev/null | jq -r '@sh "SRC_ID=\(.id) SRC_CLASS=\(.app_id)"')"
# Tell yoink that scratchpad terminals are kitty
case "$SRC_CLASS" in scratchpad|kitty-scratchpad) SRC_CLASS="kitty" ;; esac
exec kitty --app-id yoink -e yoink --source-id "$SRC_ID" --source-class "$SRC_CLASS"
